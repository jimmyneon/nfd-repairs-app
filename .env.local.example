NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMS via MacroDroid Webhook
MACRODROID_WEBHOOK_URL=https://trigger.macrodroid.com/your-webhook-id

# Email via Resend
RESEND_API_KEY=re_your_resend_api_key

# Payment Link (optional)
NEXT_PUBLIC_DEPOSIT_URL=https://your-payment-link.com

# SumUp Payment Link for £29 send-in diagnostic fee
NEXT_PUBLIC_SUMUP_DIAGNOSTIC_URL=https://pay.sumup.com/b2c/your-link-id

# Push Notifications (VAPID keys - generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Parts tracking - direct scraping of carrier websites (no API key needed)
# Shop postcode is used for DPD tracking (DPD requires delivery postcode)
SHOP_POSTCODE=SO427DH

# Cron secret for scheduled API endpoints (used by pg_cron jobs)
CRON_SECRET=your-cron-secret-key
